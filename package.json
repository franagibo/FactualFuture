{
  "name": "slay-the-spire-like",
  "version": "0.1.0",
  "description": "Slay-the-Spire-like deck-builder with Angular + Electron",
  "main": "electron/main.js",
  "scripts": {
    "build:engine": "tsc -p tsconfig.engine.json",
    "test:engine": "vitest run --config vitest.engine.config.ts",
    "sim": "vitest run src/engine/simulator/run-balance-sim.spec.ts --reporter=verbose",
    "balance:baseline": "node scripts/run-balance-baseline.mjs",
    "sim:learned": "vitest run src/engine/simulator/run-learned-vs-heuristic.spec.ts --reporter=verbose",
    "collect:bot-data": "vitest run src/engine/simulator/collect-imitation-data.spec.ts --reporter=verbose",
    "bot:full": "node scripts/run-bot-il-pipeline.mjs",
    "bot:continue": "node scripts/run-bot-il-continue.mjs",
    "start:ng": "ng serve",
    "build:ng": "ng build",
    "start:electron": "npm run build:engine && electron .",
    "clean:release": "node -e \"require('fs').rmSync('release', { recursive: true, force: true })\"",
    "build:electron": "npm run build:ng && npm run build:engine && node scripts/build-electron.js",
    "electron:dev": "concurrently \"ng build --watch\" \"wait-on dist/game-ui/index.html && electron .\"",
    "lint": "ng build --configuration=development"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.6.0",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/filter-glow": "^5.2.1",
    "@pixi/filter-noise": "^7.4.3",
    "howler": "^2.2.4",
    "pixi.js": "^8.0.0",
    "rxjs": "~7.8.0",
    "zone.js": "~0.15.0"
  },
  "build": {
    "appId": "com.slaythespirelike.game",
    "productName": "Slay the Spire Like",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-engine/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
